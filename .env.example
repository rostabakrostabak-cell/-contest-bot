# ---------- App ----------
APP_ENV=local
LOG_LEVEL=INFO
TZ=Europe/Moscow

# ---------- Telegram ----------
# Полученный у @BotFather. На сервере положить в .env, в чат не вставлять.
BOT_TOKEN=__paste_bot_token_here__
# Telegram ID единственного админа (получает все заявки на модерацию).
ADMIN_TG_ID=7529281706
# Публичный URL Mini App (https с валидным сертификатом — требование Telegram).
MINIAPP_URL=https://example.com/miniapp

# ---------- PostgreSQL ----------
POSTGRES_DB=contest
POSTGRES_USER=contest
POSTGRES_PASSWORD=changeme_please
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ---------- Контест: значения по умолчанию ----------
# Используются ТОЛЬКО для первичного посева contest_settings (id=1).
# Дальше админ меняет их через бота, и .env уже не влияет.
CONTEST_END_AT=2026-06-01T17:00:00+03:00
CONTEST_RAFFLE_AT=2026-06-01T17:15:00+03:00
DAY_GOAL=530
NIGHT_GOAL=220
